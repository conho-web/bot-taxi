VK_GROUP_TOKEN=
VK_GROUP_ID=
DRIVERS_PEER_ID=2000000001
DRIVERS_CHAT_INVITE_LINK=
PORT=3000
DATABASE_PATH=./data/bot.sqlite

# VK user_id админов через запятую
ADMIN_VK_IDS=123456789

# Long Poll: секунды ожидания ответа (по умолчанию 25, макс. 90)
# LONG_POLL_WAIT=25

# PORT=0 — не поднимать HTTP /health (только long poll)

# Водитель: false — скрыть «Завершить заказ»; true + SIMPLE — авто-завершение старых поездок при «Ожидаю»
# DRIVER_FINISH_BUTTON=true
# SIMPLE_DRIVER_FLOW=true

# Несколько параллельных заказов у одного пассажира (временно, по умолчанию вкл.)
# MULTIPLE_PASSENGER_ORDERS=false
